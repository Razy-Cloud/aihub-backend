# ===== AIHub 后端配置 =====
# 复制此文件为 .env 并填入真实值

# 服务端口
PORT=3000

# JWT 密钥（请改成随机字符串）
JWT_SECRET=aihub-dev-secret-change-this-2026
JWT_EXPIRES=7d

# ===== 大模型 API 密钥 =====
# DeepSeek (https://platform.deepseek.com 获取)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问/DashScope (https://dashscope.console.aliyun.com 获取)
QWEN_API_KEY=sk-your-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenAI (https://platform.openai.com 获取)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== 支付配置 =====
# 微信支付
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
# 支付宝
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# Stripe (https://dashboard.stripe.com/apikeys 获取)
# 测试模式 Key 以 sk_test_ 开头
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# 前端地址（部署后改为真实域名，用于 Stripe 跳转回调）
FRONTEND_URL=https://aihub-frontend-pyom.vercel.app

# 支付回调地址（部署后改为真实域名）
PAYMENT_NOTIFY_URL=http://localhost:3000/api/payment/notify

# 数据库路径
DB_PATH=./data/aihub.db

# 管理员初始账号
ADMIN_PHONE=13800000000
ADMIN_PASSWORD=admin123456
